{
  "framework": "vite",
  "devCommand": "vite --port $PORT",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron-expire-bookings",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron-send-scheduled-giftcards",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/sanvalentin", "destination": "/" },
    { "source": "/cuadre", "destination": "/" },
    { "source": "/rumcom", "destination": "/" },
    { "source": "/rumcomadmin", "destination": "/" },
    { "source": "/desobedecer-al-dolor", "destination": "/" },
    { "source": "/desobedecer-al-dolor-admin", "destination": "/" },
    { "source": "/huella-mascota", "destination": "/" },
    { "source": "/huella-mascota-admin", "destination": "/" },
    { "source": "/alianzas", "destination": "/api/alianzas" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}